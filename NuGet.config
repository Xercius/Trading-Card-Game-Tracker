<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <config>
    <!--
      GHSA-2m69-gcr7-jv3q: SQLitePCLRaw.lib.e_sqlite3 embeds a vulnerable SQLite build.
      No patched version is available yet (all versions <= 2.1.11 are affected).
      This entry suppresses the advisory so NuGet restore does not fail until a fix ships.
    -->
    <add key="auditSuppressVulnerabilities" value="GHSA-2m69-gcr7-jv3q" />
  </config>
</configuration>
